<Window x:Class="PyConnectKiosk.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Access"
        Width="340" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        WindowStyle="ToolWindow">

    <StackPanel Margin="32" VerticalAlignment="Center">
        <Border Width="56" Height="56" CornerRadius="28"
                Background="#FFF1F2" BorderBrush="#C8102E" BorderThickness="2"
                HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="⚙" FontSize="26"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="ADMIN ACCESS"
                   FontSize="13" FontWeight="Bold"
                   Foreground="#C8102E" FontFamily="Segoe UI Black"
                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Text="Enter admin PIN to continue"
                   FontSize="11" Foreground="#6B7280"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <PasswordBox x:Name="PinBox"
                     MaxLength="20"
                     FontSize="20"
                     HorizontalContentAlignment="Center"
                     Padding="10,8"
                     BorderBrush="#E5E7EB"
                     KeyDown="PinBox_KeyDown"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Padding="0,8"
                    Click="BtnCancel_Click"/>
            <Button Content="Confirm"
                    Width="100"
                    Padding="0,8"
                    Background="#C8102E"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnConfirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
