<Window x:Class="PyConnectKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PYCONNECT Kiosk"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark"
                Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgPanel"
                Color="#F8F9FA"/>
        <SolidColorBrush x:Key="AccentRed"
                Color="#C8102E"/>
        <SolidColorBrush x:Key="AccentGreen"
                Color="#16A34A"/>
        <SolidColorBrush x:Key="AccentErr"
                Color="#DC2626"/>
        <SolidColorBrush x:Key="AccentAmber"
                Color="#D97706"/>
        <SolidColorBrush x:Key="TextMain"
                Color="#111827"/>
        <SolidColorBrush x:Key="TextDim"
                Color="#6B7280"/>
        <SolidColorBrush x:Key="Border1"
                Color="#E5E7EB"/>

        <!-- Rack tile toggle -->
        <Style x:Key="RackTile"
                TargetType="ToggleButton">
            <Setter Property="Background"
                    Value="#F8F9FA"/>
            <Setter Property="BorderBrush"
                    Value="#E5E7EB"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Foreground"
                    Value="#111827"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Margin"
                    Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                    Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#FFF1F2"/>
                                <Setter TargetName="bd"
                                        Property="BorderBrush"
                                        Value="#C8102E"/>
                                <Setter TargetName="bd"
                                        Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Generic action button -->
        <Style x:Key="Btn"
                TargetType="Button">
            <Setter Property="Foreground"
                    Value="#FFFFFF"/>
            <Setter Property="Background"
                    Value="#C8102E"/>
            <Setter Property="BorderBrush"
                    Value="#C8102E"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Padding"
                    Value="36,12"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#A00D23"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                    Value="False">
                                <Setter Property="Opacity"
                                        Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline / secondary button -->
        <Style x:Key="BtnOutline"
                TargetType="Button">
            <Setter Property="Foreground"
                    Value="#C8102E"/>
            <Setter Property="Background"
                    Value="#FFFFFF"/>
            <Setter Property="BorderBrush"
                    Value="#C8102E"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Padding"
                    Value="36,12"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#FFF1F2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                    Value="False">
                                <Setter Property="Opacity"
                                        Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Large touchscreen key button (for NRIC keypad) -->
        <Style x:Key="KeyBtn"
                TargetType="Button">
            <Setter Property="Width"
                    Value="72"/>
            <Setter Property="Height"
                    Value="72"/>
            <Setter Property="Margin"
                    Value="4"/>
            <Setter Property="FontSize"
                    Value="22"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Foreground"
                    Value="#111827"/>
            <Setter Property="Background"
                    Value="#F3F4F6"/>
            <Setter Property="BorderBrush"
                    Value="#E5E7EB"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#C8102E"/>
                                <Setter Property="Foreground"
                                        Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border VerticalAlignment="Top"
                Height="64"
                Background="#FFFFFF"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource Border1}">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <Border Width="5"
                            Height="38"
                            Background="#C8102E"
                            CornerRadius="3"
                            Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ST Engineering"
                                   FontSize="16"
                                FontWeight="Bold"
                                   Foreground="#C8102E"
                                FontFamily="Segoe UI Black"/>
                        <TextBlock Text="Data Centre Access Kiosk"
                                   FontSize="11"
                                Foreground="{StaticResource TextDim}"
                                   Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StepText"
                               Foreground="#C8102E"
                            FontSize="12"
                               FontFamily="Consolas"
                            VerticalAlignment="Center"
                               Margin="0,0,24,0"/>
                    <TextBlock x:Name="ClockText"
                               Foreground="{StaticResource TextDim}"
                            FontSize="13"
                               FontFamily="Consolas"
                            VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ PAGE CONTAINER ═══════════════════════════════════════════════════ -->
        <Grid Margin="0,64,0,0">

            <!-- ── IDLE ──────────────────────────────────────────────────────── -->
            <Grid x:Name="PageIdle">
                <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Border Width="100"
                            Height="100"
                            CornerRadius="50"
                            Background="#FFF1F2"
                            BorderBrush="#C8102E"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="🔒"
                                FontSize="48"
                                HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="DATA CENTRE ACCESS"
                               Foreground="{StaticResource TextMain}"
                               FontSize="34"
                            FontWeight="Bold"
                            FontFamily="Segoe UI Black"
                               HorizontalAlignment="Center"
                            Margin="0,0,0,6"/>
                    <TextBlock Text="An escort must authenticate to begin a session."
                               Foreground="{StaticResource TextDim}"
                            FontSize="16"
                               HorizontalAlignment="Center"/>
                    <Button x:Name="BtnStartEscort"
                            Content="ESCORT SCAN TO ACTIVATE"
                            Style="{StaticResource Btn}"
                            FontSize="17"
                            Margin="0,48,0,0"
                            Click="BtnStartEscort_Click"/>
                    <!-- ADD THIS BELOW -->
                    <Button Content="RETURN KEY"
                            Style="{StaticResource BtnOutline}"
                            FontSize="17"
                            Margin="0,12,0,0"
                            Click="BtnReturnKey_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── ESCORT SCAN ───────────────────────────────────────────────── -->
            <Grid x:Name="PageEscortScan"
                    Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Margin="28,20,14,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <Grid>
                        <Image x:Name="EscortCam"
                                Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Border VerticalAlignment="Bottom"
                                Background="#CC000000"
                                Padding="14,7"
                                CornerRadius="0,0,12,12">
                            <TextBlock x:Name="EscortStatus"
                                    Text="Scanning…"
                                       Foreground="#E5E7EB"
                                    FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="1"
                        Margin="14,20,28,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <StackPanel Margin="26"
                            VerticalAlignment="Center">
                        <TextBlock Text="STEP 1 / 4"
                                Foreground="#C8102E"
                                   FontSize="11"
                                FontFamily="Consolas"
                                Margin="0,0,0,10"/>
                        <TextBlock Text="Escort Authentication"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="20"
                                FontWeight="SemiBold"
                                   FontFamily="Segoe UI Semibold"
                                TextWrapping="Wrap"/>
                        <TextBlock Text="An authorised escort must verify their identity to activate this session."
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"
                                TextWrapping="Wrap"
                                Margin="0,10,0,24"/>
                        <TextBlock x:Name="EscortTimer"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"
                                FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                Margin="0,0,0,16"/>
                        <Button Content="CANCEL"
                                Style="{StaticResource BtnOutline}"
                                Padding="0,12"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── NRIC ENTRY ─────────────────────────────────────────────────── -->
            <!--
                After the escort is verified, the visitor types their last-4 NRIC
                (e.g. "022F") using this touchscreen keypad.
                The system looks up the NRIC in users.json so it knows whose face
                to expect in the next step.
            -->
            <Grid x:Name="PageNricEntry"
                    Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="460"/>
                </Grid.ColumnDefinitions>

                <!-- Left: instructions + display -->
                <Border Grid.Column="0"
                        Margin="28,20,14,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <TextBlock Text="STEP 2 / 4"
                                Foreground="#C8102E"
                                   FontSize="11"
                                FontFamily="Consolas"
                                Margin="0,0,0,12"/>
                        <TextBlock Text="Enter Last 4 NRIC"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="26"
                                FontWeight="Bold"
                                   FontFamily="Segoe UI Semibold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="e.g.  0 2 2 F"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="14"
                                HorizontalAlignment="Center"
                                   Margin="0,6,0,32"/>

                        <!-- Escort verified badge -->
                        <Border Background="#F0FFF4"
                                CornerRadius="8"
                                BorderBrush="{StaticResource AccentGreen}"
                                BorderThickness="1"
                                Padding="16,10"
                                Margin="20,0,20,32">
                            <StackPanel>
                                <TextBlock Text="✅  ESCORT VERIFIED"
                                           Foreground="{StaticResource AccentGreen}"
                                           FontSize="10"
                                        FontFamily="Consolas"/>
                                <TextBlock x:Name="NricEscortName"
                                           Foreground="{StaticResource TextMain}"
                                           FontSize="15"
                                        FontWeight="SemiBold"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- NRIC display box -->
                        <Border Background="#FFFFFF"
                                CornerRadius="10"
                                BorderBrush="#C8102E"
                                BorderThickness="2"
                                Padding="20,14"
                                Margin="20,0">
                            <TextBlock x:Name="NricDisplay"
                                       Text="_ _ _ _"
                                       FontSize="48"
                                    FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="#C8102E"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="NricHint"
                                   Foreground="#DC2626"
                                FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Right: touchscreen keypad -->
                <Border Grid.Column="1"
                        Margin="14,20,28,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <StackPanel Margin="20"
                            VerticalAlignment="Center">

                        <!-- Digit row: 1 2 3 / 4 5 6 / 7 8 9 / 0 -->
                        <TextBlock Text="NUMBERS"
                                FontSize="10"
                                FontFamily="Consolas"
                                   Foreground="{StaticResource TextDim}"
                                   HorizontalAlignment="Center"
                                Margin="0,0,0,6"/>
                        <UniformGrid Columns="3"
                                HorizontalAlignment="Center">
                            <Button Content="1"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="1"
                                    Click="KeyBtn_Click"/>
                            <Button Content="2"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="2"
                                    Click="KeyBtn_Click"/>
                            <Button Content="3"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="3"
                                    Click="KeyBtn_Click"/>
                            <Button Content="4"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="4"
                                    Click="KeyBtn_Click"/>
                            <Button Content="5"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="5"
                                    Click="KeyBtn_Click"/>
                            <Button Content="6"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="6"
                                    Click="KeyBtn_Click"/>
                            <Button Content="7"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="7"
                                    Click="KeyBtn_Click"/>
                            <Button Content="8"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="8"
                                    Click="KeyBtn_Click"/>
                            <Button Content="9"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="9"
                                    Click="KeyBtn_Click"/>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                            <Button Content="0"
                                    Style="{StaticResource KeyBtn}"
                                    Tag="0"
                                    Click="KeyBtn_Click"/>
                        </StackPanel>

                        <!-- Letters (NRIC check digit is always A-Z) -->
                        <TextBlock Text="LETTERS"
                                FontSize="10"
                                FontFamily="Consolas"
                                   Foreground="{StaticResource TextDim}"
                                   HorizontalAlignment="Center"
                                Margin="0,12,0,6"/>
                        <UniformGrid Columns="7"
                                HorizontalAlignment="Center">
                            <Button Content="A"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="A"
                                    Click="KeyBtn_Click"/>
                            <Button Content="B"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="B"
                                    Click="KeyBtn_Click"/>
                            <Button Content="C"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="C"
                                    Click="KeyBtn_Click"/>
                            <Button Content="D"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="D"
                                    Click="KeyBtn_Click"/>
                            <Button Content="E"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="E"
                                    Click="KeyBtn_Click"/>
                            <Button Content="F"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="F"
                                    Click="KeyBtn_Click"/>
                            <Button Content="G"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="G"
                                    Click="KeyBtn_Click"/>
                            <Button Content="H"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="H"
                                    Click="KeyBtn_Click"/>
                            <Button Content="I"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="I"
                                    Click="KeyBtn_Click"/>
                            <Button Content="J"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="J"
                                    Click="KeyBtn_Click"/>
                            <Button Content="K"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="K"
                                    Click="KeyBtn_Click"/>
                            <Button Content="L"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="L"
                                    Click="KeyBtn_Click"/>
                            <Button Content="M"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="M"
                                    Click="KeyBtn_Click"/>
                            <Button Content="N"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="N"
                                    Click="KeyBtn_Click"/>
                            <Button Content="P"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="P"
                                    Click="KeyBtn_Click"/>
                            <Button Content="R"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="R"
                                    Click="KeyBtn_Click"/>
                            <Button Content="S"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="S"
                                    Click="KeyBtn_Click"/>
                            <Button Content="T"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="T"
                                    Click="KeyBtn_Click"/>
                            <Button Content="U"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="U"
                                    Click="KeyBtn_Click"/>
                            <Button Content="W"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="W"
                                    Click="KeyBtn_Click"/>
                            <Button Content="X"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="X"
                                    Click="KeyBtn_Click"/>
                            <Button Content="Y"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="Y"
                                    Click="KeyBtn_Click"/>
                            <Button Content="Z"
                                    Style="{StaticResource KeyBtn}"
                                    Width="54"
                                    Height="54"
                                    Margin="2"
                                    Tag="Z"
                                    Click="KeyBtn_Click"/>
                        </UniformGrid>

                        <!-- Backspace + Confirm row -->
                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                    Margin="0,14,0,0">
                            <Button Content="Back"
                                    Style="{StaticResource BtnOutline}"
                                    Width="130"
                                    Padding="0,12"
                                    Margin="0,0,10,0"
                                    Click="BtnNricBack_Click"/>
                            <Button x:Name="BtnNricConfirm"
                                    Content="Confirm"
                                    Style="{StaticResource Btn}"
                                    Width="160"
                                    Padding="0,12"
                                    IsEnabled="False"
                                    Click="BtnNricConfirm_Click"/>
                        </StackPanel>

                        <Button Content="CANCEL"
                                Style="{StaticResource BtnOutline}"
                                Padding="0,10"
                                Margin="0,10,0,0"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── USER SCAN ─────────────────────────────────────────────────── -->
            <Grid x:Name="PageUserScan"
                    Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Margin="28,20,14,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <Grid>
                        <Image x:Name="UserCam"
                                Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Border VerticalAlignment="Bottom"
                                Background="#CC000000"
                                Padding="14,7"
                                CornerRadius="0,0,12,12">
                            <TextBlock x:Name="UserStatus"
                                    Text="Scanning…"
                                       Foreground="#E5E7EB"
                                    FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Column="1"
                        Margin="14,20,28,20"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="12"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1">
                    <StackPanel Margin="26"
                            VerticalAlignment="Center">
                        <TextBlock Text="STEP 3 / 4"
                                Foreground="#C8102E"
                                   FontSize="11"
                                FontFamily="Consolas"
                                Margin="0,0,0,10"/>
                        <TextBlock Text="User Face Scan"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="20"
                                FontWeight="SemiBold"
                                   FontFamily="Segoe UI Semibold"/>

                        <!-- Escort verified badge -->
                        <Border Background="#F0FFF4"
                                CornerRadius="6"
                                BorderBrush="{StaticResource AccentGreen}"
                                BorderThickness="1"
                                Padding="12,9"
                                Margin="0,14,0,8">
                            <StackPanel>
                                <TextBlock Text="✅  ESCORT VERIFIED"
                                           Foreground="{StaticResource AccentGreen}"
                                           FontSize="10"
                                        FontFamily="Consolas"/>
                                <TextBlock x:Name="EscortVerifiedName"
                                           Foreground="{StaticResource TextMain}"
                                           FontSize="15"
                                        FontWeight="SemiBold"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- NRIC verified badge -->
                        <Border Background="#FFF1F2"
                                CornerRadius="6"
                                BorderBrush="#C8102E"
                                BorderThickness="1"
                                Padding="12,9"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="🪪  NRIC VERIFIED"
                                           Foreground="#C8102E"
                                           FontSize="10"
                                        FontFamily="Consolas"/>
                                <TextBlock x:Name="NricVerifiedUser"
                                           Foreground="{StaticResource TextMain}"
                                           FontSize="15"
                                        FontWeight="SemiBold"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Now scan the visitor's face to confirm identity."
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="12"
                                TextWrapping="Wrap"
                                Margin="0,0,0,24"/>
                        <TextBlock x:Name="UserTimer"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"
                                FontFamily="Consolas"
                                   HorizontalAlignment="Center"
                                Margin="0,0,0,16"/>
                        <Button Content="CANCEL"
                                Style="{StaticResource BtnOutline}"
                                Padding="0,12"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── RACK SELECTION ─────────────────────────────────────────────── -->
            <Grid x:Name="PageRackSelect"
                    Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Margin="28,16,28,0"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        Padding="22,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="STEP 4 / 4"
                                    Foreground="#C8102E"
                                       FontSize="11"
                                    FontFamily="Consolas"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Select Racks  "
                                           Foreground="{StaticResource TextMain}"
                                           FontSize="20"
                                        FontWeight="SemiBold"
                                           FontFamily="Segoe UI Semibold"/>
                                <TextBlock x:Name="AllowedCountLabel"
                                           Foreground="{StaticResource TextDim}"
                                           FontSize="13"
                                        VerticalAlignment="Bottom"
                                           Margin="0,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <Border Background="#F0FFF4"
                                    CornerRadius="6"
                                    BorderBrush="{StaticResource AccentGreen}"
                                    BorderThickness="1"
                                    Padding="10,7"
                                    Margin="0,0,10,0">
                                <TextBlock Foreground="{StaticResource TextMain}"
                                        FontSize="12">
                                    <Run Foreground="{StaticResource AccentGreen}">✅ </Run>
                                    <Run x:Name="BadgeEscort"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#FFF1F2"
                                    CornerRadius="6"
                                    BorderBrush="#C8102E"
                                    BorderThickness="1"
                                    Padding="10,7">
                                <TextBlock Foreground="{StaticResource TextMain}"
                                        FontSize="12">
                                    <Run Foreground="#C8102E">👤 </Run>
                                    <Run x:Name="BadgeUser"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                        Margin="28,10,28,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RackGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Width="195"
                                        Height="105"
                                              Style="{StaticResource RackTile}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <Grid Margin="14,9">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                Text="{Binding Rack.Tag}"
                                                   Foreground="#C8102E"
                                                FontSize="12"
                                                   FontFamily="Consolas"
                                                FontWeight="Bold"/>
                                        <TextBlock Grid.Row="1"
                                                Text="{Binding Rack.DisplayName}"
                                                   Foreground="{StaticResource TextMain}"
                                                   FontSize="11"
                                                TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2"
                                                Text="{Binding Rack.Row}"
                                                   Foreground="{StaticResource TextDim}"
                                                   FontSize="10"/>
                                    </Grid>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border Grid.Row="2"
                        Margin="28,10,28,16"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        Padding="22,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectionCount"
                                Grid.Column="0"
                                   Text="No racks selected"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="13"
                                VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <TextBlock Text="Codes per rack:"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="12"
                                    VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <Border Background="#F3F4F6"
                                    CornerRadius="6"
                                    BorderBrush="{StaticResource Border1}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnCodesDown"
                                            Content="−"
                                            Width="32"
                                            Height="32"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="#C8102E"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnCodesDown_Click"/>
                                    <TextBlock x:Name="CodesPerRackLabel"
                                            Text="1"
                                               FontSize="15"
                                            FontWeight="Bold"
                                               Foreground="#111827"
                                            Width="28"
                                               TextAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    <Button x:Name="BtnCodesUp"
                                            Content="＋"
                                            Width="32"
                                            Height="32"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="#C8102E"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnCodesUp_Click"/>
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="CodesTotalLabel"
                                    Text=""
                                       Foreground="#C8102E"
                                    FontSize="11"
                                       FontFamily="Consolas"
                                    VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                            <Button Content="CANCEL"
                                    Style="{StaticResource BtnOutline}"
                                    Margin="0,0,10,0"
                                    Click="BtnCancel_Click"/>
                            <Button x:Name="BtnGenerate"
                                    Content="GENERATE &amp; PRINT"
                                    Style="{StaticResource Btn}"
                                    IsEnabled="False"
                                    Click="BtnGenerate_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── GENERATING ─────────────────────────────────────────────────── -->
            <Grid x:Name="PageGenerating"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Border Width="100"
                            Height="100"
                            CornerRadius="50"
                            Background="#FFF1F2"
                            BorderBrush="#C8102E"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="⚡"
                                FontSize="48"
                                HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="GENERATING CODES"
                               Foreground="#C8102E"
                            FontSize="30"
                            FontWeight="Bold"
                               FontFamily="Segoe UI Black"
                            HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="GeneratingMsg"
                               Foreground="{StaticResource TextDim}"
                            FontSize="15"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- ── DISPLAY CODES ──────────────────────────────────────────────── -->
            <Grid x:Name="PageCodes"
                    Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Margin="28,16,28,0"
                        Background="#F0FFF4"
                        CornerRadius="10"
                        BorderBrush="{StaticResource AccentGreen}"
                        BorderThickness="1"
                        Padding="22,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="✅  ACCESS GRANTED — ONE-TIME CODES"
                                       Foreground="{StaticResource AccentGreen}"
                                       FontSize="12"
                                    FontFamily="Consolas"/>
                            <TextBlock Text="Present receipt to enter. Codes are single-use."
                                       Foreground="{StaticResource TextDim}"
                                    FontSize="12"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CodesTimer"
                                       Foreground="{StaticResource AccentAmber}"
                                       FontSize="12"
                                    FontFamily="Consolas"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="Auto-resets when done"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="10"
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                        Margin="28,10,28,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CodesPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="260"
                                        Margin="8"
                                        CornerRadius="10"
                                        Padding="16"
                                        Background="{Binding CardBackground}"
                                        BorderBrush="{Binding BorderColor}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Rack.Tag}"
                                                   Foreground="#C8102E"
                                                FontSize="11"
                                                   FontFamily="Consolas"
                                                FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Rack.DisplayName}"
                                                   Foreground="{StaticResource TextMain}"
                                                   FontSize="12"
                                                TextWrapping="Wrap"
                                                   Margin="0,3,0,8"/>
                                        <Border Height="1"
                                                Background="{Binding BorderColor}"
                                                Margin="0,0,0,10"
                                                Opacity="0.5"/>
                                        <ItemsControl ItemsSource="{Binding CodeEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="9"
                                                                FontFamily="Consolas"
                                                                   Foreground="{StaticResource TextDim}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Code}"
                                                                   FontSize="24"
                                                                FontWeight="Bold"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{Binding Color}"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding StatusLabel}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontSize="10"
                                                FontFamily="Consolas"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border Grid.Row="2"
                        Margin="28,10,28,16"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        Padding="22,12">
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button x:Name="BtnReprint"
                                Content="🖨  REPRINT"
                                Style="{StaticResource BtnOutline}"
                                Margin="0,0,12,0"
                                Click="BtnReprint_Click"/>
                        <Button Content="↺  NEW SESSION"
                                Style="{StaticResource Btn}"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- ── RETURN CONFIRM ─────────────────────────────────────────────── -->
            <!--
                Paste this block inside MainWindow.xaml, just before the ERROR page block.
                Find: <Grid x:Name="PageError" Visibility="Collapsed">
                Paste this entire block immediately above it.
            -->
            <Grid x:Name="PageReturn"
                    Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header banner -->
                <Border Grid.Row="0"
                        Margin="28,16,28,0"
                        Background="#FFF7ED"
                        CornerRadius="10"
                        BorderBrush="{StaticResource AccentAmber}"
                        BorderThickness="1"
                        Padding="22,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="🔑  KEY RETURN"
                                       Foreground="{StaticResource AccentAmber}"
                                       FontSize="12"
                                    FontFamily="Consolas"/>
                            <TextBlock Text="Place your key in the slot when it opens."
                                       Foreground="{StaticResource TextDim}"
                                    FontSize="12"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <!-- Escort badge -->
                            <Border Background="#F0FFF4"
                                    CornerRadius="6"
                                    BorderBrush="{StaticResource AccentGreen}"
                                    BorderThickness="1"
                                    Padding="10,7"
                                    Margin="0,0,10,0">
                                <TextBlock Foreground="{StaticResource TextMain}"
                                        FontSize="12">
                                    <Run Foreground="{StaticResource AccentGreen}">✅ </Run>
                                    <Run x:Name="ReturnEscortName"/>
                                </TextBlock>
                            </Border>
                            <!-- User badge -->
                            <Border Background="#FFF1F2"
                                    CornerRadius="6"
                                    BorderBrush="#C8102E"
                                    BorderThickness="1"
                                    Padding="10,7">
                                <TextBlock Foreground="{StaticResource TextMain}"
                                        FontSize="12">
                                    <Run Foreground="#C8102E">👤 </Run>
                                    <Run x:Name="ReturnUserName"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main content -->
                <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                        MaxWidth="560">

                    <!-- Key icon -->
                    <Border Width="100"
                            Height="100"
                            CornerRadius="50"
                            Background="#FFF7ED"
                            BorderBrush="{StaticResource AccentAmber}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24">
                        <TextBlock Text="🔑"
                                FontSize="48"
                                   HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="KEY CURRENTLY HELD"
                               Foreground="{StaticResource TextDim}"
                               FontSize="11"
                            FontFamily="Consolas"
                               HorizontalAlignment="Center"
                            Margin="0,0,0,8"/>

                    <!-- Rack name -->
                    <TextBlock x:Name="ReturnRackName"
                               Foreground="{StaticResource TextMain}"
                               FontSize="28"
                            FontWeight="Bold"
                               FontFamily="Segoe UI Semibold"
                               HorizontalAlignment="Center"
                            Margin="0,0,0,6"/>

                    <!-- Rack tag -->
                    <TextBlock x:Name="ReturnRackTag"
                               Foreground="#C8102E"
                               FontSize="14"
                            FontFamily="Consolas"
                               HorizontalAlignment="Center"
                            Margin="0,0,0,32"/>

                    <!-- Slot info -->
                    <Border Background="#F0FFF4"
                            CornerRadius="10"
                            BorderBrush="{StaticResource AccentGreen}"
                            BorderThickness="1"
                            Padding="24,16"
                            Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="RETURN TO"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="10"
                                    FontFamily="Consolas"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ReturnSlotLabel"
                                       Foreground="{StaticResource AccentGreen}"
                                       FontSize="26"
                                    FontWeight="Bold"
                                       FontFamily="Segoe UI Semibold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="The slot above will open. Place your key inside, then close the door."
                               Foreground="{StaticResource TextDim}"
                            FontSize="13"
                               TextWrapping="Wrap"
                            TextAlignment="Center"
                               HorizontalAlignment="Center"
                            Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Bottom action bar -->
                <Border Grid.Row="2"
                        Margin="28,10,28,16"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource Border1}"
                        BorderThickness="1"
                        Padding="22,12">
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button Content="CANCEL"
                                Style="{StaticResource BtnOutline}"
                                Margin="0,0,16,0"
                                Click="BtnCancel_Click"/>
                        <Button x:Name="BtnOpenReturnSlot"
                                Content="OPEN SLOT &amp; RETURN KEY"
                                Style="{StaticResource Btn}"
                                Click="BtnOpenReturnSlot_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── ERROR ──────────────────────────────────────────────────────── -->
            <Grid x:Name="PageError"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                            MaxWidth="580">
                    <Border Width="100"
                            Height="100"
                            CornerRadius="50"
                            Background="#FFF1F2"
                            BorderBrush="#DC2626"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="⚠"
                                FontSize="48"
                                HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ERROR"
                               Foreground="{StaticResource AccentErr}"
                               FontSize="30"
                            FontWeight="Bold"
                               FontFamily="Segoe UI Black"
                            HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="ErrorMsg"
                               Foreground="{StaticResource TextDim}"
                               FontSize="15"
                            TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                            TextAlignment="Center"
                               Margin="0,0,0,28"/>
                    <TextBlock x:Name="ErrorTimer"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                            FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- Footer -->
        <Border VerticalAlignment="Bottom"
                Height="28"
                Background="#F8F9FA"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource Border1}">
            <Grid Margin="16,0">
                <TextBlock Text="ST Engineering  •  EISS VIGILIUS"
                           Foreground="#D1D5DB"
                        FontSize="10"
                           FontFamily="Consolas"
                        VerticalAlignment="Center"/>
                <TextBlock Text="ESC = exit"
                           HorizontalAlignment="Right"
                        Foreground="#D1D5DB"
                           FontSize="10"
                        FontFamily="Consolas"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
